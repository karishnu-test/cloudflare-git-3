{
  "name": "cloudflare-git-3",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Unified Git & File API on Cloudflare Workers + Durable Objects",
  "license": "MIT",
  "keywords": [
    "cloudflare",
    "workers",
    "durable-objects",
    "git",
    "sqlite",
    "isomorphic-git"
  ],
  "scripts": {
    "dev": "wrangler dev",
    "build": "npm install",
    "deploy": "npm install && npx wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "hono": "^4.12.9",
    "isomorphic-git": "^1.27.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.4",
    "@cloudflare/workers-types": "^4.20241230.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2",
    "wrangler": "^3.99.0"
  }
}
